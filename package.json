{
  "name": "chart-plot",
  "version": "2026.5.31-2",
  "private": false,
  "description": "OpenClaw Chart plugin \u2014 generate bar, line, pie, scatter, and area charts as SVG images",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/zhangguiping-xydt/chart-plot"
  },
  "files": [
    "index.js",
    "index.ts",
    "openclaw.plugin.json",
    "src/",
    "tsconfig.json"
  ],
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "release": {
      "publishToClawHub": true
    },
    "install": {
      "npmSpec": "chart-generator",
      "defaultChoice": "clawhub",
      "minHostVersion": ">=2026.5.31"
    },
    "compat": {
      "pluginApi": ">=2026.5.31"
    },
    "build": {
      "openclawVersion": "2026.5.31"
    }
  }
}